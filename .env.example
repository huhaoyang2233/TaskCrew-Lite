# ============================================
# TaskCrew-Lite - 环境变量配置示例
# 复制此文件为 .env 并填入你的配置
# ============================================

# 服务配置
HOST=0.0.0.0
PORT=8000
DEBUG=true

# ============================================
# 大模型配置 - 通用模型（规划器、反思器使用）
# ============================================
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-your-openai-api-key

# ============================================
# 大模型配置 - Agent 工具调用模型（执行器使用）
# 可以与上面相同，也可以使用不同的模型
# ============================================
AGENT_MODEL=gpt-4o-mini
AGENT_BASE_URL=https://api.openai.com/v1
AGENT_API_KEY=sk-your-openai-api-key

# ============================================
# MCP 配置
# ============================================
MCP_SERVER_URL=
MCP_TIMEOUT=30

# ============================================
# 历史记录配置
# ============================================
ENABLE_HISTORY=true
HISTORY_LIMIT=10
ENABLE_HISTORY_PATTERN=false
HISTORY_PATTERN=【(.*?)】

# ============================================
# Agent 配置
# ============================================
MAX_ITERATIONS=10
MAX_REFLECTION_ROUNDS=4
